{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "FastAPI Backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["Grid/backend/run.py"],
      "port": 8742
    },
    {
      "name": "Vite Frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "Grid/frontend"
    },
    {
      "name": "Omni Frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--port", "5174"],
      "port": 5174,
      "cwd": "Invincible/frontend"
    },
    {
      "name": "Omni Site",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "5175"],
      "port": 5175,
      "cwd": "Invincible/site"
    }
  ]
}
