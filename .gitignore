Grid/.claude/settings.local.json

# Duplicate bare gitignore file
gitignore
.aider*

# Large binaries / PDFs (keep plan docs, exclude reference material)
*.exe
*.msi
*.dll
setup_latest.exe

# IDE / editor state
.dotnet-cli/
.dotnet-home/

